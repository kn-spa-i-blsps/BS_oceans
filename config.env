# Blue Spark Oceans configuration
BS_FLEET_SIZE=3
BS_VEHICLE_PREFIX=bluerov
BS_STRATEGY=lawnmower
BS_WP_FILE=/workspace/BS_oceans/waypoints/mission.txt

# Area bounds (meters)
BS_AREA_MIN_X=0.0
BS_AREA_MAX_X=20.0
BS_AREA_MIN_Y=0.0
BS_AREA_MAX_Y=20.0
BS_WP_RADIUS=1.0

# Control
BS_THRUST=35.0
BS_THRUST_MAX=70.0
BS_CTRL_HZ=2.0
BS_YAW_GAIN=1.4
BS_YAW_THRUST=20.0
BS_DEPTH_TARGET=1.0
BS_DEPTH_THRUST=25.0

# Localization
BS_LOC_RMSE_MIN=0.5
BS_LOC_RMSE_MAX=3.0
BS_LOC_RMSE_STEP=0.5

# Currents (uniform)
BS_CURRENT_X=0.2
BS_CURRENT_Y=0.0
BS_CURRENT_Z=0.0
BS_CURRENT_K=25.0

# Energy model (drag-based)
BS_DRAG_RHO=1000.0
BS_DRAG_CD=0.8
BS_DRAG_AREA=0.1
BS_PROP_EFF=0.6
BS_HOTEL_W=15.0

# Output files (optional)
BS_OUTPUT_CSV=
BS_ENERGY_CSV=
BS_EXPERIMENT_ID=

# ArduSub / ROS (required)
BS_ARDUPILOT_PLUGIN_PATH=/workspace/ardupilot_gazebo/build
BS_MAVLINK_ENDPOINTS=
BS_MAVLINK_BASE=14550
BS_ARDUPILOT_HOME=/workspace/ardupilot
BS_ARDU_FRAME=gazebo-bluerov2
BS_ARDU_MODEL=JSON
BS_ROS_DISTRO=jazzy
BS_ARDU_PARAMS=/workspace/ardupilot/Tools/Frame_params/Sub/bluerov2-4_0_0.params
